{
  "description": "token-burningman hooks for session aggregation",
  "hooks": {
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PLUGIN_ROOT\"/bin/aggregate.cjs",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
